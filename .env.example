# ─────────────────────────────────────────────────────────
# Schoolari v2 — Environment Variables
# Copy this to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────

# Supabase — get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — NEVER expose this in the browser.
# Used only in Server Actions / API Routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI — for AI features (essay helper, scholarship search)
OPENAI_API_KEY=

# Stripe — for subscription payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# USAJOBS API
USAJOBS_KEY=
USAJOBS_EMAIL=
